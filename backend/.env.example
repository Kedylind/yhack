# Copy to .env and fill in. .env is gitignored.
# For the transparent-pricing branch, use boston_gi_transparent to avoid
# overwriting the production database (boston_gi_demo on david-dev).

# MongoDB — ask team chat for the Atlas URI + password
MONGODB_URI=mongodb+srv://Kedylind:<PASSWORD>@yhack.qaw0vlj.mongodb.net/?retryWrites=true&w=majority&appName=yhack
MONGODB_DB_NAME=boston_gi_transparent

# Comma-separated browser origins allowed to call the API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# Lava AI gateway (Bearer aks_live_… key). Routes to Gemini when model is a Gemini id.
LAVA_API_KEY=
LAVA_API_BASE_URL=https://api.lava.so/v1
LAVA_GEMINI_MODEL=gemini-2.5-flash

# Optional: direct OpenAI (used only if LAVA_API_KEY is unset)
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Auth0 — required for JWT validation on /api/users/me
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_ISSUER=

JWT_SECRET_KEY=dev-secret-change-me
