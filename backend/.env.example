# Copy to .env and fill in. .env is gitignored.

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=boston_gi_demo

# Comma-separated browser origins allowed to call the API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# Lava AI gateway (Bearer aks_live_… key). Routes to Gemini when model is a Gemini id.
LAVA_API_KEY=
LAVA_API_BASE_URL=https://api.lava.so/v1
LAVA_GEMINI_MODEL=gemini-2.5-flash

# Optional: direct OpenAI (used only if LAVA_API_KEY is unset)
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Auth0 — required for JWT validation on /api/users/me
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_ISSUER=

JWT_SECRET_KEY=dev-secret-change-me
