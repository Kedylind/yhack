# Copy to .env and fill in. .env is gitignored.

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=boston_gi_demo

# Lava AI gateway (Bearer aks_live_… key). Routes to Gemini when model is a Gemini id.
# Production: set LAVA_API_KEY in your host (Railway, etc.) as a secret.
LAVA_API_KEY=
LAVA_API_BASE_URL=https://api.lava.so/v1
LAVA_GEMINI_MODEL=gemini-2.0-flash

# Optional: direct OpenAI (used only if LAVA_API_KEY is unset)
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Auth0 (optional)
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_ISSUER=

JWT_SECRET_KEY=dev-secret-change-me
