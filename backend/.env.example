# Copy to backend/.env and adjust. Never commit real secrets.

# Required: PostgreSQL (Docker Compose / Railway)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/carecost

# Required: JWT signing (long random string in production)
JWT_SECRET_KEY=dev-secret-change-me

# Optional JWT tuning
# JWT_ISSUER=carecost-api
# JWT_ACCESS_TTL_MINUTES=60

# CORS: comma-separated origins, no trailing slashes (include production frontend URL)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# Optional: /api/confirm live LLM (OpenAI-compatible). Without a key, tests use a deterministic fake.
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini

# Optional: GI assistant (Lava → Gemini). Without LAVA_API_KEY, those endpoints return 503.
# LAVA_API_KEY=
# LAVA_API_BASE_URL=https://api.lava.so/v1
# LAVA_GEMINI_MODEL=gemini-2.5-flash

# Optional: CSV import paths relative to the backend package root (defaults match repo layout)
# SAMPLES_DIR=../data/samples
# AZ_DATA_DIR=../data/az-data

# Tests only: dedicated DB for pytest (see backend/tests/conftest.py)
# TEST_DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/carecost_test
